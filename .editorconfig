root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true

[Assets/XML/Text/AdvCiv-SAS*.xml]
# <!-- custom: force ISO-8859-1 (latin1) for AdvCiv-SAS text XML files to avoid VS Code UTF-8 rewrites corrupting accented strings (e.g. "La Tène Smithy" becoming "La T�ne Smithy"). Note: not yet checked whether VS Code may revert this later. (GPT-5.3-Codex) -->
charset = latin1
