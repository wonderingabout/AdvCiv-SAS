				<GameTurnInfo><iMonthIncrement>12000</iMonthIncrement><iTurnsPerIncrement>5</iTurnsPerIncrement></GameTurnInfo>
				<!-- -15,000 to -12,000 (3,000y) → 4 turns @ 750 y/turn (9,000 mo/turn) -->
				<GameTurnInfo><iMonthIncrement>9000</iMonthIncrement><iTurnsPerIncrement>4</iTurnsPerIncrement></GameTurnInfo>
				<!-- -12,000 to -7,500 (4,500y) → 9 turns @ 500 y/turn (6,000 mo/turn) -->
				<GameTurnInfo><iMonthIncrement>6000</iMonthIncrement><iTurnsPerIncrement>9</iTurnsPerIncrement></GameTurnInfo>
