<!-- Special Building -->
<!-- custom: file imported cleanly from C:\Program Files (x86)\Steam\steamapps\common\Sid Meier's Civilization IV Beyond the Sword\Beyond the Sword\Assets\XML\Buildings and modified or not for AdvCiv-SAS anyways etc -->
<Civ4SpecialBuildingInfos xmlns="x-schema:CIV4BuildingsSchema.xml">
	<SpecialBuildingInfos>
		<!-- custom: move the tech prereq of bomb shelter from buildinginfos to specialbuildinginfos for consistency with other special buildings (may adjust if needed(ed) else keep as is anyways etc), was none -->
		<!-- custom: also change the prereq, was electricity, should be later or/and at another more relevant tech maybe in tech though -->
		<SpecialBuildingInfo>
			<Type>SPECIALBUILDING_BOMB_SHELTER</Type>
			<Description>TXT_KEY_SPECIALBUILDING_BOMB_SHELTER</Description>
			<ObsoleteTech>NONE</ObsoleteTech>
			<!-- custom: seems strictly related to nukes unlike the bunker, and not at all to tech_assembly_line which is bloated and op if i am not mistaken anyways etc, while tech_fission has some room we could use i mean more balanced if feasable in this case i mean anyways etc, was TECH_ASSEMBLY_LINE -->
			<TechPrereq>TECH_FISSION</TechPrereq>
			<TechPrereqAnyone>NONE</TechPrereqAnyone>
			<bValid>0</bValid>
			<ProductionTraits/>
			<Button>Art/Interface/Buttons/Buildings/BombShelters.dds</Button>
		</SpecialBuildingInfo>
		<!-- custom: temple prerequirement moved/changed to polytheism (requires masonry to add or not? Anyways etc) so they can be built earlier anyways etc -->
		<!-- custom: same as for the generic cathedral and monastery, use building atlas button instead (still same button, coordinates changed as is another .dds now anyways etc), button was: <Button>Art/Interface/Buttons/Buildings/Temple.dds</Button> -->
		<SpecialBuildingInfo>
			<Type>SPECIALBUILDING_TEMPLE</Type>
			<Description>TXT_KEY_SPECIALBUILDING_TEMPLE</Description>
			<ObsoleteTech>NONE</ObsoleteTech>
			<TechPrereq>TECH_POLYTHEISM</TechPrereq>
			<TechPrereqAnyone>NONE</TechPrereqAnyone>
			<bValid>1</bValid>
			<!-- custom: was TRAIT_SPIRITUAL 100 -->
			<ProductionTraits/>
			<Button>,Art/Interface/Buttons/Buildings/Cathedral_Jewish.dds,Art/Interface/Buttons/Buildings_Atlas.dds,3,7</Button>
		</SpecialBuildingInfo>
		<!-- custom: cathedral tech requirement changed to priesthood same as the monastery, also so they can be built sooner now thta music position is changed in our tech tree anyways etc anyways etc anyways etc... Should not affect gameplay due to many temples still being required, but allowing it to be sooner if needed and player meets the conditions sooner or/and wants to pursue a cultural path sooner or/and other reasons or not or yes or and other or and not anyways etc, to also match the multiple pagan holy sites (/shrines ,in a general term way not civ4 building specific term way specifically,?) anyways etc throughout history anyways etc -->
		<!-- custom: use button from the building atlas (still same image) for consistency with other generic special building buttons anyways etc, button was:
		<Button>Art/Interface/Buttons/Buildings/Cathedral.dds</Button> -->
		<SpecialBuildingInfo>
			<Type>SPECIALBUILDING_CATHEDRAL</Type>
			<Description>TXT_KEY_SPECIALBUILDING_CATHEDRAL</Description>
			<ObsoleteTech>NONE</ObsoleteTech>
			<TechPrereq>TECH_PRIESTHOOD</TechPrereq>
			<TechPrereqAnyone>NONE</TechPrereqAnyone>
			<bValid>1</bValid>
			<ProductionTraits/>
			<Button>,Art/Interface/Buttons/Buildings/Cathedral_Jewish.dds,Art/Interface/Buttons/Buildings_Atlas.dds,3,8</Button>
		</SpecialBuildingInfo>
		<!-- custom: monastery tech requirement changed to priesthood (makes more sense with our new tech tree where meditation will be much later where it is too late to start build monasteries anyways etc) -->
		<!-- custom: use this seemingly unused building atlas button anyways etc for the generic ((no religion on them) anyways etc) (base advciv's (civ4's too? Anyways etc)) monastery button, seems clearer to me than the hindu specific monastery button anyways etc, and like the generic temple and generic cathedral also having generic buttons, button was:
		<Button>Art/Interface/Buttons/Buildings/Monastery_Hindu.dds</Button> -->
		<SpecialBuildingInfo>
			<Type>SPECIALBUILDING_MONASTERY</Type>
			<Description>TXT_KEY_SPECIALBUILDING_MONASTERY</Description>
			<!-- custom: reworked monasteries, also for betetr or worse religion is still relevant in modern era (i am not a big fan of it but each do as they please maybe as long as they don't harm or maybe too ideally not annoy me as well but anyways etc..., even though it is for me to handle, at least don't act in an actively harmful way to me maybe if i may say maybe indeed but anyways etc) ; also remove scientific effect which doesn't make sense for a religious building, in fact it should be the opposite effect, religion makes dumber and further away from science for betetr or worse (i am not a fan too but society (perhaps societies if i may say but anyways etc) function as such so there must be a reason or reasons i mean in this case anyways etc anyways etc anyways etc), so no reason to obsolete this building anymore which is easier to handle/follow/grasp/manage if i may say anyways etc in terms of gameplay and modding as well at least for me maybe for others or not or yes or other but anyways etc, was TECH_SCIENTIFIC_METHOD -->
			<ObsoleteTech>NONE</ObsoleteTech>
			<TechPrereq>TECH_PRIESTHOOD</TechPrereq>
			<TechPrereqAnyone>NONE</TechPrereqAnyone>
			<bValid>1</bValid>
			<!-- custom: makes it more interesting to think of them as being willing to meditate rather than going to a generic religious office maybe at least i'd want to represent it as such in advciv-sas anyways etc -->
			<ProductionTraits>
				<ProductionTrait>
					<ProductionTraitType>TRAIT_SPIRITUAL</ProductionTraitType>
					<iProductionTrait>100</iProductionTrait>
				</ProductionTrait>
			</ProductionTraits>
			<Button>,Art/Interface/Buttons/Buildings/Cathedral_Jewish.dds,Art/Interface/Buttons/Buildings_Atlas.dds,7,11</Button>
		</SpecialBuildingInfo>
	</SpecialBuildingInfos>
</Civ4SpecialBuildingInfos>
