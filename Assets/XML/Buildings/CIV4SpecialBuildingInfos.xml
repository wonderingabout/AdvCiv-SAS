<!-- Special Building -->
<!-- custom: file imported cleanly from C:\Program Files (x86)\Steam\steamapps\common\Sid Meier's Civilization IV Beyond the Sword\Beyond the Sword\Assets\XML\Buildings and modified or not for AdvCiv-SAS -->
<Civ4SpecialBuildingInfos xmlns="x-schema:CIV4BuildingsSchema.xml">
	<SpecialBuildingInfos>
		<!-- custom: move the tech prereq of bomb shelter from buildinginfos to specialbuildinginfos for consistency with other special buildings (may adjust if neededed else keep as is), was none -->
		<!-- custom: also change the prereq, was electricity, should be later or/and at another more relevant tech maybe in tech though -->
		<SpecialBuildingInfo>
			<Type>SPECIALBUILDING_BOMB_SHELTER</Type>
			<Description>TXT_KEY_SPECIALBUILDING_BOMB_SHELTER</Description>
			<ObsoleteTech>NONE</ObsoleteTech>
			<!-- custom: seems strictly related to nukes unlike the bunker, and not at all to tech_assembly_line which is bloated and op, while tech_fission has some room we could use i mean more balanced if feasable, was TECH_ASSEMBLY_LINE -->
			<TechPrereq>TECH_FISSION</TechPrereq>
			<TechPrereqAnyone>NONE</TechPrereqAnyone>
			<bValid>0</bValid>
			<ProductionTraits/>
			<Button>Art/Interface/Buttons/Buildings/BombShelters.dds</Button>
		</SpecialBuildingInfo>
		<!-- custom: temple prerequirement moved/changed to polytheism (requires masonry to add or not?) so they can be built earlier -->
		<!-- custom: same as for the generic cathedral and monastery, use building atlas button instead (still same button, coordinates changed as is another .dds now) -->
		<SpecialBuildingInfo>
			<Type>SPECIALBUILDING_TEMPLE</Type>
			<Description>TXT_KEY_SPECIALBUILDING_TEMPLE</Description>
			<ObsoleteTech>NONE</ObsoleteTech>
			<TechPrereq>TECH_POLYTHEISM</TechPrereq>
			<TechPrereqAnyone>NONE</TechPrereqAnyone>
			<bValid>1</bValid>
			<ProductionTraits>
				<ProductionTrait>
					<ProductionTraitType>TRAIT_SPIRITUAL</ProductionTraitType>
					<iProductionTrait>100</iProductionTrait>
				</ProductionTrait>
			</ProductionTraits>
			<Button>,Art/Interface/Buttons/Buildings/Cathedral_Jewish.dds,Art/Interface/Buttons/Buildings_Atlas.dds,3,7</Button>
		</SpecialBuildingInfo>
		<!-- custom: cathedral tech requirement changed to priesthood same as the monastery, also so they can be built sooner now thta music position is changed in our tech tree. Should not affect gameplay due to many temples still being required, but allowing it to be sooner if needed and player meets the conditions sooner or/and wants to pursue a cultural path sooner among other reasons if any, to also match the multiple pagan holy sites (/shrines, in a general term way not civ4 building specific term way specifically) throughout history -->
		<!-- custom: use button from the building atlas (still same image) for consistency with other generic special building buttons -->
		<SpecialBuildingInfo>
			<Type>SPECIALBUILDING_CATHEDRAL</Type>
			<Description>TXT_KEY_SPECIALBUILDING_CATHEDRAL</Description>
			<ObsoleteTech>NONE</ObsoleteTech>
			<!-- custom: was TECH_PRIESTHOOD (now removed) -->
			<TechPrereq>TECH_MONOTHEISM</TechPrereq>
			<TechPrereqAnyone>NONE</TechPrereqAnyone>
			<bValid>1</bValid>
			<ProductionTraits/>
			<Button>,Art/Interface/Buttons/Buildings/Cathedral_Jewish.dds,Art/Interface/Buttons/Buildings_Atlas.dds,3,8</Button>
		</SpecialBuildingInfo>
		<!-- custom: monastery tech requirement changed to priesthood (makes more sense with our new tech tree where meditation will be much later where it is too late to start build monasteries) -->
		<!-- custom: use this seemingly unused building atlas button for the generic ((no religion on them)) (base advciv's (civ4's too?)) monastery button, seems clearer to me than the hindu specific monastery button, and like the generic temple and generic cathedral also having generic buttons, button was:
		<Button>Art/Interface/Buttons/Buildings/Monastery_Hindu.dds</Button> -->
		<SpecialBuildingInfo>
			<Type>SPECIALBUILDING_MONASTERY</Type>
			<Description>TXT_KEY_SPECIALBUILDING_MONASTERY</Description>
			<!-- custom: GPT-5.2-Codex: Long_Comments_XML.txt #16 -->
			<ObsoleteTech>NONE</ObsoleteTech>
			<!-- custom: was TECH_PRIESTHOOD (now removed) -->
			<TechPrereq>TECH_MONARCHY</TechPrereq>
			<TechPrereqAnyone>NONE</TechPrereqAnyone>
			<bValid>1</bValid>
			<!-- custom: makes it more interesting to think of them as being willing to meditate rather than going to a generic religious office maybe at least i'd want to represent it as such in advciv-sas -->
			<ProductionTraits>
				<ProductionTrait>
					<ProductionTraitType>TRAIT_SPIRITUAL</ProductionTraitType>
					<iProductionTrait>100</iProductionTrait>
				</ProductionTrait>
			</ProductionTraits>
			<Button>,Art/Interface/Buttons/Buildings/Cathedral_Jewish.dds,Art/Interface/Buttons/Buildings_Atlas.dds,7,11</Button>
		</SpecialBuildingInfo>
	</SpecialBuildingInfos>
</Civ4SpecialBuildingInfos>
